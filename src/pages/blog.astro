---
import MainLayout from '../layouts/MainLayout.astro';
const base = import.meta.env.BASE_URL;
---
<MainLayout title="Blog">
  <article class="card blog-card">
    <div class="blog-image">
      <img src={`${base}/images/home.jpg`} alt="New Home" onerror="this.style.display='none'"/>
      <div class="image-label">Gratitude & Growth</div>
    </div>
    
    <div class="blog-content">
      <h2>Reflections on a Beautiful Year</h2>
      <p>I am so grateful for the blessings I have been given in this lifetime. Both my children are about to graduate, I'm finally a homeowner <strong>[Yay!]</strong>, and ***** Eye Care has provided me the perfect environment and tools needed to become an even better version of myself.</p>
      <p class="signature">— Karen</p>
    </div>
  </article>
</MainLayout>

<style>
  .blog-card { padding: 0; overflow: hidden; border-left: none; border-top: 6px solid var(--accent-blue); }
  .blog-image { height: 300px; background: #d1d5db; position: relative; }
  .blog-image img { width: 100%; height: 100%; object-fit: cover; }
  .image-label { position: absolute; bottom: 20px; left: 20px; background: var(--primary-blue); color: white; padding: 5px 15px; border-radius: 4px; }
  .blog-content { padding: 2rem; line-height: 1.8; font-size: 1.1rem; }
  .signature { margin-top: 2rem; font-family: 'Playfair Display', serif; font-style: italic; color: var(--primary-blue); font-size: 1.5rem; }
</style>

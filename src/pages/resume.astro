---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Resume">
    <div class="card">
        <h2>Professional Journey</h2>
        <div style="border-left: 2px solid var(--sage); padding-left: 1.5rem; margin-top: 1rem;">
            <h4 style="margin-bottom:0.2rem;">Optical Consultant — ***** Eye Care</h4>
            <small>Nov 2025 – Current</small>
            
            <h4 style="margin-top:2rem; margin-bottom:0.2rem;">Optometric Technician — National Vision</h4>
            <small>Jan 2024 – Sep 2025</small>
            <p style="font-size: 0.95rem;">Expertise in tonometer, autorefractor, and retinal imaging. Managed remote optometrist assistance systems.</p>
            
            <h4 style="margin-top:2rem; margin-bottom:0.2rem;">Retail Banker — Woodforest Bank</h4>
            <small>Feb 2022 – Dec 2023</small>
        </div>
    </div>
</MainLayout>

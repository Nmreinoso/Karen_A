---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Resume">
  <div class="card resume-card">
    <h2 class="section-title">Work Experience</h2>
    
    <div class="job">
      <div class="job-header">
        <strong>Optical Consultant — ***** Eye Care</strong>
        <span class="date-tag">Nov 2025 - Current</span>
      </div>
    </div>

    <div class="job">
      <div class="job-header">
        <strong>Optometric Technician — National Vision</strong>
        <span class="date-tag">Jan 2024 - Sep 2025</span>
      </div>
      <p>Specialized in remote systems and clinical pre-testing (tonometer, retinal imaging).</p>
    </div>
    </div>
</MainLayout>

<style>
  .resume-card { padding: 2rem; }
  .section-title { color: var(--primary-blue); border-bottom: 2px solid var(--soft-blue); padding-bottom: 0.5rem; }
  .job-header { display: flex; justify-content: space-between; margin-top: 1.5rem; color: var(--primary-blue); }
  .date-tag { background: var(--soft-blue); padding: 2px 10px; border-radius: 4px; font-size: 0.85rem; }
</style>

---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Home">
  <div class="hero-section card">
    <div class="profile-layout">
      <div class="image-placeholder main-photo">
        <span>[Professional Photo Here]</span>
      </div>
      <div class="bio-text">
        <h1>Karen Arze</h1>
        <p class="intro-quote">"Quick to adapt and eager to learn, I am reliable enough to take on leadership roles..."</p>
        <div class="contact-strip">
           <span>📍 Virginia</span> | <span>📞 757-515-****</span>
        </div>
      </div>
    </div>
  </div>

  <div class="interests-grid">
    <div class="interest-card card">
      <h3>🏖️ Walks & Sunrises</h3>
      <p>Even if it's a bit of a drive, it's always worth it.</p>
    </div>
    <div class="interest-card card">
      <div class="image-placeholder interest-photo">
        <span>[Family/Children Photo Here]</span>
      </div>
      <h3>❤️ My Children</h3>
      <p>My Son and Daughter are my pride and joy—they'll always be my babies.</p>
    </div>
  </div>
</MainLayout>

<style>
  .profile-layout { display: flex; gap: 2rem; align-items: center; padding: 2rem; }
  .image-placeholder { 
    background: #dee2e6; 
    border: 2px dashed #adb5bd; 
    display: flex; align-items: center; justify-content: center; color: #6c757d;
  }
  .main-photo { width: 180px; height: 180px; border-radius: 50%; flex-shrink: 0; }
  .interest-photo { width: 100%; height: 150px; border-radius: 8px; margin-bottom: 1rem; }
  .intro-quote { font-size: 1.1rem; border-left: 4px solid var(--primary-blue); padding-left: 1rem; font-style: italic; }
  .interests-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2rem; }
</style>

---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Home">
	<section class="hero">
		<h1>Welcome, I'm Karen</h1>
		<p class="intro">Quick to adapt and eager to learn, I am reliable enough to take on leadership roles and always strive for work that can model what I would like to see in others.</p>
	</section>

	<section class="details">
		<div class="contact-card">
			<h3>Contact Info</h3>
			<p>📍 {Astro.props.state || 'Virginia'}</p>
			<p>📞 757-515-****</p>
			<p>✉️ karen**********@yahoo.com</p>
		</div>
	</section>

	<section class="interests">
		<h2>Outside the Office</h2>
		<div class="grid">
			<div class="interest">
				<h3>Dancing 💃</h3>
				<p>Bachata, Meringue, and currently learning Jazz and Salsa. This is when I feel most like myself!</p>
			</div>
			<div class="interest">
				<h3>My Children ❤️</h3>
				<p>My Son and Daughter are my pride and joy! They may be grown, but they'll always be my babies.</p>
			</div>
			<div class="interest">
				<h3>Coastal Sunrises</h3>
				<p>Even if it's a drive, long walks on the beach at dawn are always worth it.</p>
			</div>
		</div>
	</section>
</MainLayout>
